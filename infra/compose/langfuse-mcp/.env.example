# Deploy this file to /root/langfuse-mcp/.env on the VPS (chmod 0600).
# DO NOT commit a populated copy.

# In-cluster Langfuse hostname (the shared docker network resolves this).
LANGFUSE_HOST=http://langfuse-web:3000

# Required: scout-prod project credentials. Server refuses to start without them.
LANGFUSE_PROD_PUBLIC_KEY=
LANGFUSE_PROD_SECRET_KEY=

# Optional: scout-dev project credentials. Missing → server boots in
# prod_only degraded mode; calls with project=scout-dev return
# {degraded: true, reason: "project_unconfigured"}.
LANGFUSE_DEV_PUBLIC_KEY=
LANGFUSE_DEV_SECRET_KEY=

# Bearer token(s) accepted by clients. Comma-separated list during the
# 4-step rotation overlap window (see README §Rotation). The singular
# LANGFUSE_MCP_TOKEN is also honoured for back-compat.
LANGFUSE_MCP_TOKENS=
# LANGFUSE_MCP_TOKEN=

# Bind address; the Traefik label points to port 4000. Override only if you
# need to run two replicas behind different ports.
MCP_BIND=0.0.0.0:4000

# Hard ceiling on tool windows (hours). Tools that accept window_minutes
# clamp to <= this * 60.
LANGFUSE_MCP_ALLOWED_TIME_WINDOW_HOURS=24

# SSE poll interval against Langfuse (seconds). Default 5; tune up if the
# Langfuse worker QPS budget gets tight.
# LANGFUSE_MCP_POLL_INTERVAL_SEC=5

# Server log level (Python logging name).
# LANGFUSE_MCP_LOG_LEVEL=INFO
