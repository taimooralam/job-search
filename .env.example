# Root pipeline example environment for local and VPS worker processes.
# Runner-specific variables remain documented in `.env.runner.example`.

# =============================================================================
# CORE DATA STORES
# =============================================================================
MONGODB_URI=mongodb://user:password@host:27017/jobs?authSource=jobs

# =============================================================================
# LANGFUSE (optional)
# =============================================================================
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk_...
LANGFUSE_SECRET_KEY=sk_...

# =============================================================================
# ITERATION 4 PRE-ENRICH DAG FLAGS
# =============================================================================
PREENRICH_STAGE_DAG_ENABLED=false
PREENRICH_DAG_CANARY_ALLOWLIST=
PREENRICH_DAG_CANARY_PCT=0
PREENRICH_LEGACY_SEQUENCE_ENABLED=true
PREENRICH_WRITE_CV_READY=false
PREENRICH_ACCEPT_READY_COMPAT=true
PREENRICH_DISABLE_REDIS_OUTBOX=false
PREENRICH_STAGE_ALLOWLIST=
PREENRICH_STAGE_LEASE_SECONDS=600
PREENRICH_STAGE_HEARTBEAT_SECONDS=60
PREENRICH_SNAPSHOT_REVALIDATE_WINDOW_SECONDS=120
LANGFUSE_PREENRICH_TRACING_ENABLED=false
LANGFUSE_CAPTURE_FULL_PROMPTS=false
